# Example 1 - Item without {{- if .HasDefinition}} definition{{- end}}{{- if .HasProperties}} properties{{- end}}
resource "fabric_{{.Type}}" "example" {
  display_name = "example"
  workspace_id = "00000000-0000-0000-0000-000000000000"
}

{{- if .HasDefinition}}

# Example 2 - Item with definition bootstrapping only
resource "fabric_{{.Type}}" "example_definition_bootstrap" {
  display_name              = "example"
  description               = "example with definition bootstrapping"
  workspace_id              = "00000000-0000-0000-0000-000000000000"
  definition_update_enabled = false
  format                    = "Default"
  definition = {
    "{{.DefinitionPath}}" = {
      source = "${local.path}/{{.DefinitionPath}}.tmpl"
    }
  }
}

# Example 3 - Item with definition update when source or tokens changed
resource "fabric_{{.Type}}" "example_definition_update" {
  display_name = "example"
  description  = "example with definition update when source or tokens changed"
  workspace_id = "00000000-0000-0000-0000-000000000000"
  format       = "Default"
  definition = {
    "{{.DefinitionPath}}" = {
      source = "${local.path}/{{.DefinitionPath}}.tmpl"
      tokens = {
        "MyValue1" = "my value 1"
        "MyValue2" = "my value 2"
      }
    }
  }
}

# Example 4 - Item with custom tokens delimiter
resource "fabric_{{.Type}}" "example_custom_delimiter" {
  display_name = "example"
  description  = "example with custom tokens delimiter"
  workspace_id = "00000000-0000-0000-0000-000000000000"
  format       = "Default"
  definition = {
    "{{.DefinitionPath}}" = {
      source           = "${local.path}/{{.DefinitionPath}}.tmpl"
      tokens_delimiter = "##"
      tokens = {
        "MyValue1" = "my value 1"
        "MyValue2" = "my value 2"
      }
    }
  }
}

# Example 5 - Item with parameters processing mode
resource "fabric_{{.Type}}" "example_parameters" {
  display_name = "example"
  description  = "example with parameters processing mode"
  workspace_id = "00000000-0000-0000-0000-000000000000"
  format       = "Default"
  definition = {
    "{{.DefinitionPath}}" = {
      source          = "${local.path}/{{.DefinitionPath}}.tmpl"
      processing_mode = "parameters"
      parameters = [
        {
          type  = "JsonPathReplace"
          find  = "$.properties.source.workspaceId"
          value = "00000000-0000-0000-0000-000000000001"
        },
        {
          type  = "TextReplace"
          find  = "OldValue"
          value = "NewValue"
        }
      ]
    }
  }
}
{{- end}}
